{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/css/(.*)", "dest": "public/css/$1" },
    { "src": "/signup.html", "dest": "public/signup.html" },
    { "src": "/dashboard.html", "dest": "public/dashboard.html" },
    { "src": "/admin.html", "dest": "public/admin.html" },
    { "src": "/index.html", "dest": "public/index.html" },
    { "src": "/signup", "dest": "public/signup.html" },
    { "src": "/dashboard", "dest": "public/dashboard.html" },
    { "src": "/admin", "dest": "public/admin.html" },
    { "src": "/", "dest": "public/index.html" }
  ]
}
